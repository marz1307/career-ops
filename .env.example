# career-ops — Environment Variables
# Copy this file to .env and fill in your values.
#
#   cp .env.example .env

# ── Bright Data (for SERP-backed portal scanning) ─────
# Sign up at https://brightdata.com and create an API token.
# The skill onboarding prompt will write this for you on first run.
# BRIGHTDATA_API_KEY=your_brightdata_api_key

# ── Notion (optional — REST API for headless scripts) ───────────────
# Notion access has TWO surfaces:
#   1. Claude Code interactive sessions — use the hosted Notion MCP
#      (OAuth, no token needed here).
#   2. Headless scripts (notion-query.mjs, pace-alarm.mjs, scheduled
#      `claude -p` runs) — use NOTION_TOKEN below, an internal-integration
#      token starting with `ntn_` (or legacy `secret_`).
#
# Get one at https://www.notion.com/profile/integrations, then in each
# database you want the integration to touch: ··· → Connections →
# Add connections → select your integration. See modes/notion-tracker.md
# for the database-vs-data-source distinction.
# NOTION_TOKEN=ntn_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Optional: explicit API keys for ad-hoc scripts ─────────────────
# Most agentic work runs through Claude Code (no API key needed here).
# These are only required if you write a standalone script that calls
# the API directly.
# ANTHROPIC_API_KEY=your_anthropic_key_here
# OPENAI_API_KEY=your_openai_key_here

# ── Playwright headless config (rarely needed) ─────────────────────
# PLAYWRIGHT_BROWSERS_PATH=
# PLAYWRIGHT_HEADLESS=true
