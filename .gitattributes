# Normalize text files to LF in the repo, regardless of platform.
# Stops the "LF will be replaced by CRLF" warning storm on every commit.
* text=auto eol=lf

# PowerShell stays CRLF (Windows convention).
*.ps1 text eol=crlf

# Binary assets — never normalise.
*.pdf binary
*.jpg binary
*.jpeg binary
*.png binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.eot binary
*.mov binary
*.mp4 binary
*.zip binary
